{
  "providers": {
    "orcarouter": {
      "baseUrl": "https://api.orcarouter.ai/v1",
      "api": "openai-completions",
      "apiKey": "!security find-generic-password -a \"$(whoami)\" -s orcarouter -w",
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": true,
        "supportsUsageInStreaming": true,
        "maxTokensField": "max_tokens"
      },
      "models": [
        {
          "id": "z-ai/glm-5.2",
          "name": "Z.ai: GLM 5.2 via OrcaRouter",
          "reasoning": true,
          "thinkingLevelMap": {
            "off": null,
            "minimal": null,
            "low": null,
            "medium": "high",
            "high": "high",
            "xhigh": "max"
          },
          "input": ["text"],
          "contextWindow": 1000000,
          "maxTokens": 128000,
          "cost": {
            "input": 1.4,
            "output": 4.4,
            "cacheRead": 0,
            "cacheWrite": 0
          }
        }
      ]
    }
  }
}
